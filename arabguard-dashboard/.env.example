# ─── ArabGuard Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values

# FastAPI Backend URL
VITE_API_BASE_URL=http://localhost:8000

# Hugging Face Configuration
VITE_HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_HF_MODEL_URL=https://api-inference.huggingface.co/models/d12o6aa/ArabGuard

# App Settings
VITE_APP_NAME=ArabGuard
VITE_APP_VERSION=1.0.0
VITE_ENABLE_MOCK_DATA=true

# Security (change in production)
VITE_SESSION_TIMEOUT_MINUTES=30
