# ─── ArabGuard Backend Environment ──────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=info
WORKERS=1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the React dashboard
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── ArabGuard Model ───────────────────────────────────────────────────────────
MODEL_ID=d12o6aa/ArabGuard
USE_AI=true
# Device: auto | cpu | cuda | mps
DEVICE=auto
# Threshold to BLOCK (default 120)
BLOCK_THRESHOLD=120
# Treat FLAG as BLOCKED
BLOCK_ON_FLAG=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Analytics persistence (file-based, upgrade to Redis/DB for production) ────
ANALYTICS_LOG_FILE=data/threat_log.jsonl
